# Ghostty optimized baseline

# Appearance
theme = Catppuccin Mocha
background-opacity = 0.90
background-blur = 16
macos-titlebar-style = tabs
unfocused-split-opacity = 0.92

# Font
font-family = "Maple Mono NF CN"
font-size = 14
font-thicken = true
font-feature = calt
font-feature = liga

# Window behavior
window-save-state = always
window-inherit-working-directory = true
window-inherit-font-size = true
window-padding-x = 4
window-padding-y = 4
window-padding-balance = true

# Quick terminal
keybind = global:ctrl+grave_accent=toggle_quick_terminal
quick-terminal-screen = main
quick-terminal-position = top
quick-terminal-size = 50%
quick-terminal-autohide = true
quick-terminal-animation-duration = 0.12

# Shell integration
shell-integration-features = cursor,sudo,title,ssh-terminfo,ssh-env

# Scrollback: keep large enough but avoid excessive memory use.
scrollback-limit = 20000000

# Cursor and interaction
cursor-style = block
cursor-style-blink = false
mouse-hide-while-typing = true
copy-on-select = clipboard
clipboard-trim-trailing-spaces = true

# macOS behavior
confirm-close-surface = false
macos-option-as-alt = true
