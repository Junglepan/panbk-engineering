{
  "includeCoAuthoredBy": false,
  "model": "claude-sonnet-4-6",
  "extraKnownMarketplaces": {
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "enabledPlugins": {
    "codex@openai-codex": true
  },
  "permissions": {
    "deny": [
      "Read(.env)",
      "Read(**/.env)",
      "Read(**/*.env.*)",
      "Read(**/*.pem)",
      "Read(**/id_rsa*)",
      "Read(**/*.key)",
      "Bash(git reset --hard *)",
      "Bash(git clean -fd *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)"
    ],
    "ask": [
      "WebFetch(*)",
      "WebSearch(*)",
      "Bash(git push *)",
      "Bash(git tag *)",
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(npm publish *)",
      "Bash(pip install *)",
      "Bash(brew install *)",
      "Bash(npm install *)",
      "Edit(**/.github/workflows/**)"
    ],
    "allow": [
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(ls *)",
      "Bash(rg *)",
      "Bash(fd *)",
      "Bash(mise *)",
      "Bash(direnv *)"
    ]
  }
}
